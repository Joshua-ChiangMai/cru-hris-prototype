# ---------------------------------------------------------------------------
# HRIS P1 Prototype — Docker Compose & local development
# Copy to .env:  cp .env.example .env
# ---------------------------------------------------------------------------

NODE_ENV=development

# PostgreSQL (postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hris_p0
POSTGRES_PORT=5432

# Backend (backend service) — host machine / local npm
PORT=3001
BACKEND_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hris_p0?schema=public
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Frontend (frontend service) — browser must reach API on host
FRONTEND_PORT=3000
# URL used by the browser (not Docker internal DNS)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Docker-only (set automatically in compose for backend container)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/hris_p0?schema=public
